@model SACCOBlockChainSystem.Models.ViewModels.FinancialReportViewModel

<div class="card shadow-sm mt-4" style="border: none; border-radius: 10px;">
    <div class="card-header bg-white py-3" style="border-bottom: 2px solid #3f2b96;">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0" style="color: #3f2b96; font-weight: 600;">
                <i class="fas fa-money-bill-wave me-2"></i> Cash Flow Statement
            </h5>
            <span class="badge bg-info p-2">
                <i class="fas fa-calendar me-1"></i> @Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")
            </span>
        </div>
    </div>

    <div class="card-body">
        <!-- Operating Activities -->
        <div class="mb-4">
            <h6 class="text-primary mb-3" style="font-weight: 600;">
                <i class="fas fa-industry me-2"></i> OPERATING ACTIVITIES
            </h6>
            <table class="table table-sm">
                @foreach (var item in Model.CashFlow.OperatingActivities)
                {
                    <tr>
                        <td style="padding: 8px; border: none;">@item.Description</td>
                        <td style="padding: 8px; text-align: right; border: none; font-weight: 500; color: @(item.Amount >= 0 ? "#28a745" : "#dc3545");">
                            @item.Amount.ToString("N2")
                        </td>
                    </tr>
                }
                <tr class="border-top">
                    <td style="padding: 10px; font-weight: 600;">Net Cash from Operating Activities</td>
                    <td style="padding: 10px; text-align: right; font-weight: 600; color: #17a2b8;">
                        @Model.CashFlow.NetOperating.ToString("N2")
                    </td>
                </tr>
            </table>
        </div>

        <!-- Investing Activities -->
        <div class="mb-4">
            <h6 class="text-success mb-3" style="font-weight: 600;">
                <i class="fas fa-chart-line me-2"></i> INVESTING ACTIVITIES
            </h6>
            <table class="table table-sm">
                @foreach (var item in Model.CashFlow.InvestingActivities)
                {
                    <tr>
                        <td style="padding: 8px; border: none;">@item.Description</td>
                        <td style="padding: 8px; text-align: right; border: none; font-weight: 500; color: @(item.Amount >= 0 ? "#28a745" : "#dc3545");">
                            @item.Amount.ToString("N2")
                        </td>
                    </tr>
                }
                <tr class="border-top">
                    <td style="padding: 10px; font-weight: 600;">Net Cash from Investing Activities</td>
                    <td style="padding: 10px; text-align: right; font-weight: 600; color: #17a2b8;">
                        @Model.CashFlow.NetInvesting.ToString("N2")
                    </td>
                </tr>
            </table>
        </div>

        <!-- Financing Activities -->
        <div class="mb-4">
            <h6 class="text-warning mb-3" style="font-weight: 600;">
                <i class="fas fa-hand-holding-usd me-2"></i> FINANCING ACTIVITIES
            </h6>
            <table class="table table-sm">
                @foreach (var item in Model.CashFlow.FinancingActivities)
                {
                    <tr>
                        <td style="padding: 8px; border: none;">@item.Description</td>
                        <td style="padding: 8px; text-align: right; border: none; font-weight: 500; color: @(item.Amount >= 0 ? "#28a745" : "#dc3545");">
                            @item.Amount.ToString("N2")
                        </td>
                    </tr>
                }
                <tr class="border-top">
                    <td style="padding: 10px; font-weight: 600;">Net Cash from Financing Activities</td>
                    <td style="padding: 10px; text-align: right; font-weight: 600; color: #17a2b8;">
                        @Model.CashFlow.NetFinancing.ToString("N2")
                    </td>
                </tr>
            </table>
        </div>

        <!-- Cash Summary -->
        <div class="mt-4 p-3" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 8px; color: white;">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-0">Beginning Cash Balance</h5>
                </div>
                <div class="col-md-6 text-end">
                    <h4 class="mb-0">@Model.CashFlow.BeginningCash.ToString("N2")</h4>
                </div>
            </div>
            <div class="row align-items-center mt-2">
                <div class="col-md-6">
                    <h5 class="mb-0">Net Cash Flow</h5>
                </div>
                <div class="col-md-6 text-end">
                    <h4 class="mb-0 @(Model.CashFlow.NetCashFlow >= 0 ? "text-white" : "text-danger")">
                        @(Model.CashFlow.NetCashFlow >= 0 ? "+" : "")@Model.CashFlow.NetCashFlow.ToString("N2")
                    </h4>
                </div>
            </div>
            <hr class="bg-white">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-0">Ending Cash Balance</h5>
                </div>
                <div class="col-md-6 text-end">
                    <h3 class="mb-0">@Model.CashFlow.EndingCash.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card-footer bg-white py-3">
        <div class="row align-items-center">
            <div class="col-md-6">
                <small class="text-muted">
                    <i class="fas fa-info-circle me-1"></i>
                    Generated: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                </small>
            </div>
            <div class="col-md-6 text-end">
                <button class="btn btn-sm btn-outline-primary" onclick="window.print()">
                    <i class="fas fa-print me-1"></i> Print
                </button>
            </div>
        </div>
    </div>
</div>
@model SACCOBlockChainSystem.Models.ViewModels.FinancialReportViewModel

<div class="card shadow-sm mt-4" style="border: none; border-radius: 10px;">
    <div class="card-header bg-white py-3" style="border-bottom: 2px solid #3f2b96;">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0" style="color: #3f2b96; font-weight: 600;">
                <i class="fas fa-balance-scale me-2"></i> Trial Balance
            </h5>
            <div>
                <span class="badge bg-info p-2 me-2">
                    <i class="fas fa-calendar me-1"></i> @Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")
                </span>
                <span class="badge @(Model.IsBalanced ? "bg-success" : "bg-danger") p-2">
                    <i class="fas @(Model.IsBalanced ? "fa-check-circle" : "fa-exclamation-circle") me-1"></i>
                    @(Model.IsBalanced ? "Balanced" : "Unbalanced")
                </span>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="trialBalanceTable">
                <thead style="background-color: #3f2b96; color: white;">
                    <tr>
                        <th style="padding: 15px;">Account No</th>
                        <th style="padding: 15px;">Account Name</th>
                        <th style="padding: 15px;">Start Date</th>
                        <th style="padding: 15px; text-align: center;">End Date</th>
                        <th style="padding: 15px; text-align: right;">Debit</th>
                        <th style="padding: 15px; text-align: right;">Credit</th>
                        @* <th style="padding: 15px; text-align: right;">Balance</th> *@
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.TrialBalance.OrderBy(x => x.AccountNo))
                    {
                        <tr>
                            <td style="padding: 12px; font-weight: 500;">@item.AccountNo</td>
                            <td style="padding: 12px;">@item.AccountName</td>
                            <td style="padding: 12px;">
                                <i class="fas fa-calendar me-1"></i> @Model.StartDate.ToString("dd/MM/yyyy")
                            </td>
                            <td style="padding: 12px; text-align: center;">
                                <i class="fas fa-calendar me-1"></i> @Model.EndDate.ToString("dd/MM/yyyy")
                            </td>
                            <td style="padding: 12px; text-align: right; color: #28a745; font-weight: 500;">
                                @item.Debit.ToString("N2")
                            </td>
                            <td style="padding: 12px; text-align: right; color: #dc3545; font-weight: 500;">
                                @item.Credit.ToString("N2")
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot style="background-color: #f8f9fa; font-weight: 600; border-top: 2px solid #3f2b96;">
                    <tr>
                        <td colspan="4" style="padding: 15px; text-align: right; font-size: 15px;">Totals:</td>
                        <td style="padding: 15px; text-align: right; color: #28a745; font-size: 15px;">
                            @Model.TotalDebits.ToString("N2")
                        </td>
                        <td style="padding: 15px; text-align: right; color: #dc3545; font-size: 15px;">
                            @Model.TotalCredits.ToString("N2")
                        </td>
                        <td style="padding: 15px; text-align: right; color: #17a2b8; font-size: 15px;">
                            @((Model.TotalDebits - Model.TotalCredits).ToString("N2"))
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white py-3">
        <div class="row align-items-center">
            <div class="col-md-6">
                <small class="text-muted">
                    <i class="fas fa-info-circle me-1"></i>
                    Total Accounts: @Model.TrialBalance.Count | Generated: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                </small>
            </div>
            <div class="col-md-6 text-end">
                <button class="btn btn-sm btn-outline-primary" onclick="printTable('trialBalanceTable', 'Trial Balance')">
                    <i class="fas fa-print me-1"></i> Print
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function printTable(tableId, title) {
        var printWindow = window.open('', '_blank');
        var table = document.getElementById(tableId);
        var html = '<html><head><title>' + title + '</title>';
        html += '<style>body { font-family: Arial, sans-serif; } table { border-collapse: collapse; width: 100%; } th { background-color: #343a40; color: white; padding: 10px; } td { padding: 8px; border-bottom: 1px solid #dee2e6; } .text-right { text-align: right; }</style>';
        html += '</head><body>';
        html += '<h2 style="color: #3f2b96;">' + title + '</h2>';
        html += '<p>Period: @Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")</p>';
        html += table.outerHTML;
        html += '</body></html>';
        printWindow.document.write(html);
        printWindow.document.close();
        printWindow.print();
    }
</script>